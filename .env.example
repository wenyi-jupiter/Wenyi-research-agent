# LLM API Keys - Minimax (optional, legacy)
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id

# LLM API Keys - Qwen (Aliyun DashScope) - Recommended
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Default LLM Provider (qwen or minimax)
DEFAULT_LLM_PROVIDER=qwen
DEFAULT_QWEN_MODEL=qwen-plus

# Qwen Web Search Configuration (DashScope built-in, no extra API key needed)
# Enable web search for Qwen models (true/false)
QWEN_ENABLE_SEARCH=true
# Search strategy: turbo (fast), max (thorough), agent (multi-round)
QWEN_SEARCH_STRATEGY=turbo
# Force search even if model thinks it's not needed (true/false)
QWEN_FORCED_SEARCH=false

# Database Configuration
DATABASE_URL=postgresql+asyncpg://agent_user:agent_password@localhost:5432/agent_engine

# Embedding Configuration
# Provider options: "dashscope" (recommended) or "mock" (for testing, no API required)
EMBEDDING_PROVIDER=dashscope
# Model: text-embedding-v4 (Aliyun DashScope)
EMBEDDING_MODEL=text-embedding-v4
# Dimension: text-embedding-v4 supports 2048, 1536, 1024 (default), 768, 512, 256, 128, 64
EMBEDDING_DIMENSION=1024

# Execution Limits
MAX_TOKENS=100000
MAX_STEPS=50
MAX_TOOL_CALLS=100
EXECUTION_TIMEOUT=600

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Skills Directory (optional)
SKILLS_DIR=./skills
